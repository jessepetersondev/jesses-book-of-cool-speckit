{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/phase-plan.schema.json",
  "title": "SpecKit Phase Plan",
  "type": "object",
  "required": [
    "feature_id",
    "phases"
  ],
  "properties": {
    "feature_id": {
      "type": "string",
      "minLength": 1
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "phase_id",
          "name",
          "order",
          "kind",
          "scope",
          "validation"
        ],
        "properties": {
          "phase_id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "order": {
            "type": "integer",
            "minimum": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "artifact_build",
              "artifact_repair",
              "mode_lock",
              "implementation"
            ]
          },
          "depends_on_phases": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "scope": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "validation": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
